# Mock mode does not need this file.
# To call your own API, copy this file to .env, fill one provider below, and run with --mode llm.
LLM_PROVIDER=zhipu
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4-flash
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
CODEX_COMMAND=codex
CODEX_ARGS=exec --sandbox read-only
CODEX_TIMEOUT_MS=120000
MC_VERSION=1.21
MINECRAFT_DIR=
ARCHITECT_DATAPACKS_DIR=
ARCHITECT_DATAPACKS_TARGET=
MINECRAFT_LAUNCH_COMMAND=
